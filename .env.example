# ─────────────────────────────────────────────────────────
# BFI Fraud Detection — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ─── Authentication ───────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Default admin credentials (will be saved to DB on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Groq API ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Local STT (faster-whisper) ───────────────────────────
# Model size: tiny, base, small, medium, large-v3
LOCAL_WHISPER_MODEL=base
# Device: cpu, cuda (use cpu for OrangePi)
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8

# ─── Local LLM (Ollama / RKLLama) ─────────────────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5:1.5b
# Use /api/generate for Ollama, /v1/chat/completions for OpenAI-compat
LOCAL_LLM_ENDPOINT_TYPE=ollama

# ─── STT / LLM Mode ───────────────────────────────────────
# Options: api, local, auto (auto = try api first, fallback to local)
STT_MODE=auto
LLM_MODE=auto

# ─── Audio ────────────────────────────────────────────────
SAMPLE_RATE=16000
CHANNELS=1
CHUNK_SIZE=512
# Device index: -1 = auto-detect, 0+ = specific device
AUDIO_DEVICE_INDEX=-1

# ─── VAD ──────────────────────────────────────────────────
VAD_THRESHOLD=300
VAD_SILENCE_DURATION=1.5
VAD_MIN_SPEECH_DURATION=0.5
VAD_MAX_SEGMENT_DURATION=15.0
# Silero VAD (more accurate, uses ONNX): true/false
VAD_USE_SILERO=false

# ─── Recording ────────────────────────────────────────────
PRE_BUFFER_SECONDS=10
POST_BUFFER_SECONDS=15
# Encoding: wav or ogg
RECORDING_FORMAT=ogg
# Only record on: FRAUD, SUSPICIOUS, or BOTH
RECORD_ON_VERDICT=BOTH

# ─── Retention ────────────────────────────────────────────
RETENTION_DAYS=7

# ─── MQTT (optional, leave blank to disable) ──────────────
MQTT_ENABLED=false
MQTT_BROKER_HOST=192.168.1.100
MQTT_BROKER_PORT=1883
MQTT_TOPIC=bfi/fraud/alerts
MQTT_CLIENT_ID=bfi-fraud-detector
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false
MQTT_QOS=1
MQTT_RETAIN=false

# ─── External Audio Upload API (optional) ─────────────────
AUDIO_UPLOAD_ENABLED=false
AUDIO_UPLOAD_URL=https://your-api.example.com/audio/upload
AUDIO_UPLOAD_API_KEY=
AUDIO_UPLOAD_TIMEOUT=30
# JSON path to extract unique ID from response, e.g. "data.id" or "id"
AUDIO_UPLOAD_ID_PATH=id

# ─── Storage ──────────────────────────────────────────────
STORAGE_PATH=/app/storage
DATABASE_PATH=/app/storage/fraud_detection.db

# ─── Server ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
CORS_ORIGINS=http://localhost:3000,http://0.0.0.0:3000

# ─── Timeouts ─────────────────────────────────────────────
STT_TIMEOUT=120
LLM_TIMEOUT=90
